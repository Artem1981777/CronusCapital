# Cronus Capital - environment variables
# Server (Vercel) - used by api/*.js serverless functions

# Groq API key for the live reasoning trace (/api/consult)
GROQ_API_KEY=your_groq_api_key_here

# x402 paywall / settlement
CRONUS_PAYTO=0xdc6778c5f8cc74b10aed11c48306d4cfc5737fbd
X402_NETWORK=arc-testnet
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
ARC_CHAIN_ID=5042002
SIGNAL_PRICE=20000
SIGNAL_MAX_AGE_SECONDS=1800

# Optional RPC override for on-chain verification / metrics
SIGNAL_RPC_URL=https://rpc.testnet.arc.network
METRICS_BLOCK_WINDOW=2000000

# Only for the helper scripts that send REAL payments
# (scripts/pay-and-consult.mjs, scripts/pay-with-memo.mjs). Never commit a real key.
TREASURY_PRIVATE_KEY=your_funded_test_wallet_private_key_here

# Client (Vite) - optional; current build uses sensible defaults
# VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here
